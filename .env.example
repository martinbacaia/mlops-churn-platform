# Copy to .env and adjust as needed. .env is gitignored.

# MLflow tracking — local SQLite by default; point to a remote tracking server in prod.
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db
MLFLOW_EXPERIMENT_NAME=churn

# Model registry — the serving layer is model-agnostic and loads whichever
# version is in MODEL_STAGE for the registered model named MODEL_NAME.
MODEL_NAME=churn_classifier
MODEL_STAGE=Production

# Data
DATA_DIR=data

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Reproducibility
RANDOM_STATE=42
